# =========================================
# Server Configuration
# =========================================
PORT=3003
NODE_ENV=development

# =========================================
# Database PostgreSQL
# Format: postgresql://user:password@host:port/database
# =========================================
DATABASE_URL=postgresql://sawerdian:YOUR_PASSWORD@localhost:5432/sawerdian

# =========================================
# Admin Account
# Username default: admin
# Password WAJIB diganti setelah setup pertama!
# =========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Session secret (string random panjang untuk keamanan)
SESSION_SECRET=ganti_dengan_string_random_panjang_minimal_32_karakter

# Cookie secure (opsional, default auto-detect)
# Set 'true' jika deploy di balik HTTPS proxy (Nginx + Let's Encrypt) tanpa trust proxy
# Biarkan kosong/komen untuk auto-detect (recommended)
# COOKIE_SECURE=true


# =========================================
# Default QRIS Static String
# String ini didapat dengan decode gambar qris_dianrama.png
# menggunakan tool atau endpoint /api/admin/qris/preview
# Bisa di-overwrite dari dashboard admin (Settings)
# =========================================
QRIS_STATIC=

# =========================================
# Webhook Secret untuk auto-confirm (by token, legacy)
# String random yang dipakai Macrodroid untuk verifikasi
# saat POST /api/donations/:token/paid?secret=XXXXX
# (Tidak dipakai lagi oleh endpoint /api/macrodroid/confirm,
#  yang sekarang pakai Basic Auth di bawah)
# =========================================
WEBHOOK_SECRET=ganti_dengan_string_random

# =========================================
# Macrodroid Basic Auth (untuk endpoint /api/macrodroid/confirm)
# Macrodroid akan kirim header: Authorization: Basic base64(USER:PASS)
# =========================================
MACRODROID_USERNAME=macrodroid
MACRODROID_PASSWORD=ganti_password_macrodroid_kuat


# =========================================
# CORS (opsional)
# Kosongkan jika frontend & backend di domain yang sama
# Pisahkan dengan koma untuk multiple origin
# Contoh: https://sawer.domain.com,https://admin.domain.com
# =========================================
ALLOWED_ORIGIN=

# =========================================
# Upload limit (bytes, default 2MB)
# =========================================
MAX_UPLOAD_SIZE=2097152

# =========================================
# Base URL (untuk generate link donasi di webhook payload)
# Contoh: https://sawer.domain.com
# =========================================
BASE_URL=http://localhost:3003
